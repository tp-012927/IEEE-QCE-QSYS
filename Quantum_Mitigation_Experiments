        "#data analysis code block\n",
        "\n",
        "import json\n",
        "import os\n",
        "from itertools import product\n",
        "import matplotlib.pyplot as plt\n",
        "from qiskit.visualization import plot_histogram\n",
        "from google.colab import drive\n",
        "import numpy as np\n",
        "\n",
        "topologies = [\"Line\", \"Grid\", \"Heavy-Hex\"]\n",
        "mitigations = [\"None\", \"ZNE\", \"MEM\", \"PT\"]\n",
        "\n",
        "# load\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Instead of hardcoding the folder, use the variable\n",
        "file_path = os.path.join(RUN_DIR, \"quantum_data.json\")\n",
        "\n",
        "with open(file_path, \"r\") as f:\n",
        "    data = json.load(f)\n",
        "\n",
        "print(f\"Loaded {len(data)} entries\")\n",
        "\n",
        "# Output folder for figures\n",
        "output_dir = os.path.dirname(file_path)\n",
        "\n",
        "def generate_bitstrings(n):\n",
        "    return [\"\".join(bits) for bits in product(\"01\", repeat=n)]\n",
        "\n",
        "def filter_data(circuit=None, topology=None, mitigation=None, qubits=None):\n",
        "    results = data\n",
        "    if circuit:\n",
        "        results = [d for d in results if d[\"circuit\"] == circuit]\n",
        "    if topology:\n",
        "        results = [d for d in results if d[\"topology\"] == topology]\n",
        "    if mitigation:\n",
        "        results = [d for d in results if d[\"mitigation\"] == mitigation]\n",
        "    if qubits:\n",
        "        results = [d for d in results if d[\"qubits\"] == qubits]\n",
        "    return results\n",
        "\n",
        "def success_prob(entry):\n",
        "    d = entry[\"data\"]\n",
        "    n = len(entry[\"qubits\"])\n",
        "\n",
        "    if entry[\"mitigation\"] == \"ZNE\":\n",
        "        raw_prob = float(d.get(\"mitigated_ideal_prob\", 0))\n",
        "        return np.clip(raw_prob, 0.0, 1.0)\n",
        "\n",
        "    shots = 4096\n",
        "    target_states = [\"0\" * n, \"1\" * n]\n",
        "    values = []\n",
        "    for k in target_states:\n",
        "        v = d.get(k, 0)\n",
        "        if entry[\"mitigation\"] == \"MEM\":\n",
        "            values.append(v)\n",
        "        else:\n",
        "            values.append(v / shots)\n",
        "\n",
        "    return np.clip(sum(values), 0.0, 1.0)\n",
        "\n",
        "\n",
        "def clean_counts(d):\n",
        "    if not isinstance(d, dict):\n",
        "        return {}\n",
        "\n",
        "    clean = {}\n",
        "    for k, v in d.items():\n",
        "        # Allow standard bits ir the specific ZNE key\n",
        "        if (isinstance(k, str) and set(k).issubset({\"0\",\"1\"})) or k == \"mitigated_ideal_prob\":\n",
        "            if isinstance(v, (int, float)):\n",
        "                clean[k] = v\n",
        "    return clean\n",
        "\n",
        "# Histogram\n",
        "entries = filter_data(circuit=\"Bell\", topology=\"Line\", mitigation=\"None\", qubits=[0,1])\n",
        "\n",
        "print(\"Entries found:\", len(entries))\n",
        "if len(entries) == 0:\n",
        "    raise ValueError(\"No data found\")\n",
        "\n",
        "entry = entries[0]\n",
        "\n",
        "cleaned = clean_counts(entry[\"data\"])\n",
        "print(\"CLEANED DATA:\", cleaned)\n",
        "\n",
        "if len(cleaned) == 0:\n",
        "    raise ValueError(\"Data is invalid for histogram\")\n",
        "\n",
        "fig = plot_histogram(cleaned)\n",
        "fig.suptitle(\"Bell State (Line, No Mitigation)\")\n",
        "plt.show()\n",
        "plt.close()\n",
        "\n",
        "# Mitigation Comparison\n",
        "entries = filter_data(circuit=\"Bell\", topology=\"Line\", qubits=[0,1])\n",
        "\n",
        "counts_dict = {}\n",
        "\n",
        "for e in entries:\n",
        "    d = clean_counts(e[\"data\"])\n",
        "\n",
        "    if e[\"mitigation\"] in [\"None\", \"PT\"] and len(d) > 0:\n",
        "        counts_dict[e[\"mitigation\"]] = d\n",
        "\n",
        "print(\"COUNTS_DICT:\", counts_dict)\n",
        "\n",
        "if len(counts_dict) == 0:\n",
        "    raise ValueError(\"No valid data for mitigation comparison\")\n",
        "\n",
        "fig = plot_histogram(list(counts_dict.values()), legend=list(counts_dict.keys()))\n",
        "fig.suptitle(\"Mitigation Comparison (Bell, Line)\")\n",
        "plt.show()\n",
        "plt.close()\n",
        "\n",
        "# topology Comparison\n",
        "fig, axs = plt.subplots(1, 3, figsize=(16,6))\n",
        "\n",
        "for i, topo in enumerate(topologies):\n",
        "    entries = filter_data(\n",
        "        circuit=\"Bell\",\n",
        "        topology=topo,\n",
        "        mitigation=\"None\",\n",
        "        qubits=[0,1]\n",
        "    )\n",
        "    if entries:\n",
        "        plot_histogram(clean_counts(entries[0][\"data\"]), ax=axs[i])\n",
        "        axs[i].set_title(topo)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(output_dir, \"topology_comparison.png\"))\n",
        "plt.show()\n",
        "plt.close()\n",
        "\n",
        "# GHZ3 Comparison\n",
        "fig, axs = plt.subplots(1, 3, figsize=(16,6))\n",
        "\n",
        "for i, topo in enumerate(topologies):\n",
        "    entries = filter_data(\n",
        "        circuit=\"GHZ3\",\n",
        "        topology=topo,\n",
        "        mitigation=\"None\",\n",
        "        qubits=[0,1,2]\n",
        "    )\n",
        "    if entries:\n",
        "        plot_histogram(clean_counts(entries[0][\"data\"]), ax=axs[i])\n",
        "        axs[i].set_title(f\"GHZ3 - {topo}\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(output_dir, \"ghz3_comparison.png\"))\n",
        "plt.show()\n",
        "plt.close()\n",
        "# GHZ4 Comparison\n",
        "fig, axs = plt.subplots(1, 3, figsize=(16,6))\n",
        "\n",
        "for i, topo in enumerate(topologies):\n",
        "    entries = filter_data(\n",
        "        circuit=\"GHZ4\",\n",
        "        topology=topo,\n",
        "        mitigation=\"None\",\n",
        "        qubits=[0,1,2,3]\n",
        "    )\n",
        "    if entries:\n",
        "        plot_histogram(clean_counts(entries[0][\"data\"]), ax=axs[i])\n",
        "        axs[i].set_title(f\"GHZ4 - {topo}\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(output_dir, \"ghz4_comparison.png\"))\n",
        "plt.show()\n",
        "plt.close()\n",
        "\n",
        "# helper function for value labels\n",
        "def add_value_labels(bars):\n",
        "    for bar in bars:\n",
        "        height = bar.get_height()\n",
        "\n",
        "        plt.text(\n",
        "            bar.get_x() + bar.get_width() / 2,\n",
